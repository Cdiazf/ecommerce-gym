NODE_ENV=production
APP_DOMAIN=shop.example.com
PORT=3000
CORS_ORIGIN=https://shop.example.com

KAFKA_BROKERS=kafka:29092

PGHOST=postgres
PGPORT=5432
PGUSER=postgres
PGPASSWORD=change-me
PGPOOL_MAX=20

CATALOG_DB_NAME=catalog_db
INVENTORY_DB_NAME=inventory_db
ORDERS_DB_NAME=orders_db
PAYMENTS_DB_NAME=payments_db
SHIPPING_DB_NAME=shipping_db
AUTH_DB_NAME=auth_db

AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_EXPIRES_IN=3600
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_SECONDS=60
AUTH_LOGIN_BLOCK_SECONDS=300
AUTH_REGISTER_MAX_ATTEMPTS=10
AUTH_REGISTER_WINDOW_SECONDS=300
AUTH_REGISTER_BLOCK_SECONDS=300
ADMIN_USER=admin
ADMIN_PASSWORD=replace-admin-password
DEMO_USER=cliente
DEMO_PASS=replace-demo-password

YAPE_PENDING_TTL_MINUTES=10
YAPE_PENDING_SWEEP_MS=30000

VITE_API_URL=https://shop.example.com/api

CULQI_API_BASE_URL=https://api.culqi.com/v2
CULQI_SECRET_KEY=sk_live_replace_me
CULQI_WEBHOOK_SECRET=replace-webhook-secret
CULQI_WEBHOOK_SIGNATURE_MODE=none
CULQI_WALLET_ORDER_EXPIRATION_MINUTES=15
