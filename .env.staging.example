NODE_ENV=staging
APP_DOMAIN=staging.shop.example.com
PORT=3000
CORS_ORIGIN=https://staging.shop.example.com

KAFKA_BROKERS=kafka:29092

PGHOST=postgres
PGPORT=5432
PGUSER=postgres
PGPASSWORD=change-me
PGPOOL_MAX=20

CATALOG_DB_NAME=catalog_db
INVENTORY_DB_NAME=inventory_db
ORDERS_DB_NAME=orders_db
PAYMENTS_DB_NAME=payments_db
SHIPPING_DB_NAME=shipping_db
AUTH_DB_NAME=auth_db

AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_EXPIRES_IN=3600
ADMIN_USER=admin
ADMIN_PASSWORD=replace-admin-password
DEMO_USER=cliente
DEMO_PASS=replace-demo-password

YAPE_PENDING_TTL_MINUTES=10
YAPE_PENDING_SWEEP_MS=30000

VITE_API_URL=https://staging.shop.example.com/api

CULQI_API_BASE_URL=https://api.culqi.com/v2
CULQI_SECRET_KEY=sk_test_replace_me
CULQI_WEBHOOK_SECRET=replace-webhook-secret

BACKEND_IMAGE=ghcr.io/cdiazf/ecommerce-gym-backend:latest
FRONTEND_IMAGE=ghcr.io/cdiazf/ecommerce-gym-frontend:latest
