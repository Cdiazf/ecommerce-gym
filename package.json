{
  "name": "agent-ai",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:gateway": "nest start",
    "start:catalog": "ts-node -r tsconfig-paths/register src/microservices/catalog/main.ts",
    "start:cart": "ts-node -r tsconfig-paths/register src/microservices/cart/main.ts",
    "start:inventory": "ts-node -r tsconfig-paths/register src/microservices/inventory/main.ts",
    "start:orders": "ts-node -r tsconfig-paths/register src/microservices/orders/main.ts",
    "start:payments": "ts-node -r tsconfig-paths/register src/microservices/payments/main.ts",
    "start:shipping": "ts-node -r tsconfig-paths/register src/microservices/shipping/main.ts",
    "start:frontend": "npm run dev --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "db:postgres:up": "docker compose -f docker-compose.postgres.yml up -d",
    "db:postgres:down": "docker compose -f docker-compose.postgres.yml down",
    "db:migrate": "bash scripts/db/run-migrations.sh",
    "db:migrate:compose": "bash scripts/db/run-compose-migrations.sh",
    "db:backup": "bash scripts/db/backup-postgres.sh",
    "db:backup:compose": "bash scripts/db/backup-postgres-compose.sh",
    "db:restore:compose": "bash scripts/db/restore-postgres-compose.sh",
    "ops:check:env": "bash scripts/ops/check-production-env.sh",
    "test:local:idempotency-culqi": "bash ./scripts/tests/test-local-idempotency-culqi.sh",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:flow": "bash ./integration-test.sh"
  },
  "dependencies": {
    "@nestjs/config": "^4.0.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@tanstack/react-query": "^5.90.21",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "kafkajs": "^2.2.4",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
